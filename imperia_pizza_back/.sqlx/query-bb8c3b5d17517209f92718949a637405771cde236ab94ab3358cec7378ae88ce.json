  "query": "\n        SELECT \n            id AS order_id, \n            delivery_type, \n            address, \n            user_name, \n            phone_number, \n            payment_method, \n            total_price, \n            COALESCE(to_char(created_at, 'YYYY-MM-DD\"T\"HH24:MI:SS\"Z\"'), '') AS created_at\n        FROM orders\n        WHERE id = $1\n        ",
