  "query": "\n        SELECT \n            id AS order_id,\n            status,\n            delivery_type,\n            address,\n            phone_number,\n            total_price,\n            COALESCE(to_char(created_at, 'YYYY-MM-DD\"T\"HH24:MI:SS\"Z\"'), '') AS created_at\n        FROM orders\n        WHERE status NOT IN ('completed', 'cancelled')\n        ORDER BY created_at DESC\n        ",
